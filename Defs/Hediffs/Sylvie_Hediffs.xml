<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <HediffDef>
    <defName>SylvieRace_InitialTrauma</defName>
    <label>SylvieRace_InitialTrauma_label</label>
    <description>SylvieRace_InitialTrauma_description</description>
    <hediffClass>HediffWithComps</hediffClass>
    <tendable>true</tendable>
    <isBad>true</isBad>
    <initialSeverity>1.0</initialSeverity>
    <minSeverity>0.0</minSeverity>
    <maxSeverity>1.0</maxSeverity>
    <stages>
      <li>
        <minSeverity>0.0</minSeverity>
        <painOffset>0.05</painOffset>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.1</offset>
          </li>
        </capMods>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_TendDuration">
        <baseTendDurationHours>12</baseTendDurationHours>
        <severityPerDayTended>-0.2</severityPerDayTended>
      </li>
    </comps>
  </HediffDef>

	<HediffDef>
		<defName>SylvieRace_NurseParalysis</defName>
		<label>Nurse uniform paralysis</label>
		<description>A temporary paralysis caused by the nurse uniform's automatic healing process.</description>
		<hediffClass>HediffWithComps</hediffClass>
		<defaultLabelColor>(0.8, 0.4, 0.8)</defaultLabelColor>
		<isBad>false</isBad>
		<initialSeverity>1.0</initialSeverity>
		<maxSeverity>1.0</maxSeverity>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>2500</disappearsAfterTicks>
			</li>
		</comps>
		<stages>
			<li>
				<label>paralyzed</label>
				<capMods>
					<li>
						<capacity>Moving</capacity>
						<setMax>0.0</setMax>
					</li>
					<li>
						<capacity>Manipulation</capacity>
						<setMax>0.0</setMax>
					</li>
				</capMods>
			</li>
		</stages>
	</HediffDef>
</Defs>
