<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <ThingDef ParentName="ApparelBase">
    <defName>Purpledress</defName> <!-- 唯一ID -->
    <label>紫色连衣裙</label> <!-- 游戏内名字 -->
    <description>紫色连衣裙。</description>
    
    <!-- 掉在地上时的样子 -->
    <graphicData>
      <texPath>Things/Clothes/Purpledress_Female_south</texPath> <!-- 贴图路径 -->
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>

    <!-- 基础属性 -->
    <statBases>
      <MaxHitPoints>120</MaxHitPoints>
      <Mass>2.0</Mass>
      <StuffEffectMultiplierArmor>0.2</StuffEffectMultiplierArmor> <!-- 材料对护甲的影响系数 -->
      <StuffEffectMultiplierInsulation_Cold>0.2</StuffEffectMultiplierInsulation_Cold>
      <StuffEffectMultiplierInsulation_Heat>0.2</StuffEffectMultiplierInsulation_Heat>
      <EquipDelay>2</EquipDelay>
      
      <!-- 固定护甲值-->
      <ArmorRating_Sharp>0.15</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.15</ArmorRating_Blunt>
      <ArmorRating_Heat>0.15</ArmorRating_Heat>
    </statBases>
    <costStuffCount>40</costStuffCount>
    <stuffCategories>
      <li>Fabric</li>
    </stuffCategories>

    <apparel>
      <wornGraphicPath>Things/Clothes/Purpledress</wornGraphicPath>
      
      <bodyPartGroups>
        <li>Torso</li>
        <li>Neck</li>
        <li>Shoulders</li>
        <li>Arms</li>
        <li>Legs</li>
      </bodyPartGroups>
      
      <layers>
        <li>Middle</li>
      </layers>
      
      <tags>
        <li>SylvieApparel</li>
      </tags>
    </apparel>

   <tradeTags>
        <li>SylvieClothesTag</li>
   </tradeTags>
</ThingDef>


